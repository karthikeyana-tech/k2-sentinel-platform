########################################
# K² Sentinel Environment Configuration
########################################

# ======================================
# Application
# ======================================

PROJECT_NAME=K² Sentinel API
VERSION=0.1.0
API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000

DEBUG=True

# ======================================
# Environment
# ======================================

ENVIRONMENT=development

# ======================================
# Logging
# ======================================

LOG_LEVEL=INFO

# ======================================
# Database
# (PostgreSQL - will be used later)
# ======================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=k2_sentinel
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme

# ======================================
# Redis
# (Used later for caching/background jobs)
# ======================================

REDIS_HOST=localhost
REDIS_PORT=6379

# ======================================
# JWT Authentication
# (Will be configured later)
# ======================================

JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ======================================
# CORS
# ======================================

ALLOWED_ORIGINS=http://localhost:3000

# ======================================
# AI Services
# (Future integrations)
# ======================================

OPENAI_API_KEY=
GOOGLE_API_KEY=

# ======================================
# Maps
# ======================================

GOOGLE_MAPS_API_KEY=

# ======================================
# Weather
# ======================================

OPENWEATHER_API_KEY=